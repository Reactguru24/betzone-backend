# Betzone Backend Configuration
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=8080
ENVIRONMENT=development

# JWT Configuration
# IMPORTANT: Change this to a strong secret in production!
JWT_SECRET=your-secret-key-change-in-production

# MySQL Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=betzone
DB_PASSWORD=your_mysql_password_here
DB_NAME=betzone

# Betkraft API Configuration
BETKRAFT_BASE_URL=https://api.staging.betkraft.co.uk
API_KEY=your_betkraft_api_key_here
APP_KEY=your_betkraft_app_key_here

# Callback URL Configuration
# Complete URL for all Betkraft callbacks
CALLBACK_URL=https://your-ngrok-url.ngrok.io/api/v1/callbacks

# Optional: Logging
LOG_LEVEL=info
LOG_FORMAT=json
